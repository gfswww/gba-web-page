<header class="sticky top-0 z-50 bg-white shadow-md">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center py-4">
      <!-- Logo -->
      <div class="flex items-center space-x-2">
        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
          <span class="text-white font-bold text-xl">GBA</span>
        </div>
        <div>
          <h1 class="text-primary font-bold text-xl">大灣區經貿協會</h1>
          <p class="text-xs text-gray-500">Greater Bay Area Business Association</p>
        </div>
      </div>
      <!-- 桌面端導航 -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="#home" class="text-primary font-medium hover:text-secondary transition-colors">首頁</a>
        <a href="#about" class="text-gray-600 font-medium hover:text-secondary transition-colors">關於我們</a>
        <a href="#news" class="text-gray-600 font-medium hover:text-secondary transition-colors">最新動態</a>
        <a href="#gallery" class="text-gray-600 font-medium hover:text-secondary transition-colors">活動照片</a>
        <a href="#partners" class="text-gray-600 font-medium hover:text-secondary transition-colors">合作夥伴</a>
        <a href="#contact" class="text-gray-600 font-medium hover:text-secondary transition-colors">聯絡我們</a>
        <button class="btn-primary">加入協會</button>
      </nav>
      <!-- 移動端菜單按鈕 -->
      <button id="mobile-menu-button" class="md:hidden text-gray-600 focus:outline-none">
        <i class="fas fa-bars text-2xl"></i>
      </button>
    </div>
    <!-- 移動端導航菜單 -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <nav class="flex flex-col space-y-4">
        <a href="#home" class="text-primary font-medium hover:text-secondary transition-colors py-2">首頁</a>
        <a href="#about" class="text-gray-600 font-medium hover:text-secondary transition-colors py-2">關於我們</a>
        <a href="#news" class="text-gray-600 font-medium hover:text-secondary transition-colors py-2">最新動態</a>
        <a href="#gallery" class="text-gray-600 font-medium hover:text-secondary transition-colors py-2">活動照片</a>
        <a href="#partners" class="text-gray-600 font-medium hover:text-secondary transition-colors py-2">合作夥伴</a>
        <a href="#contact" class="text-gray-600 font-medium hover:text-secondary transition-colors py-2">聯絡我們</a>
        <button class="btn-primary w-full mt-4">加入協會</button>
      </nav>
    </div>
  </div>
</header>
<script>
  // 移動端菜單切換
  document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    if (mobileMenuButton && mobileMenu) {
      mobileMenuButton.addEventListener('click', function() {
        mobileMenu.classList.toggle('hidden');
        const icon = mobileMenuButton.querySelector('i');
        if (mobileMenu.classList.contains('hidden')) {
          icon.classList.remove('fa-times');
          icon.classList.add('fa-bars');
        } else {
          icon.classList.remove('fa-bars');
          icon.classList.add('fa-times');
        }
      });
    }
  });
</script>
